# ── NotebookLM config ────────────────────────────────────────────
NOTEBOOK_ID=your_notebook_id_here

# ── Mode: "auto" (launches Firefox) or "connect" (attaches to running Firefox) ──
MODE=auto

# ── Firefox binary (system Firefox = extensions & VPN work) ──────
FIREFOX_PATH=C:\Program Files\Mozilla Firefox\firefox.exe

# ── Profile directory ────────────────────────────────────────────
# Leave EMPTY to auto-detect your default Firefox profile.
# Or set a specific path:
# USER_PROFILE=C:\Users\YourName\AppData\Roaming\Mozilla\Firefox\Profiles\xxxxxxxx.default-release
USER_PROFILE=

# ── Fallback: Playwright creates a fresh profile here ────────────
USER_DATA_DIR=./firefox-profile

# ── Connect mode (MODE=connect) ──────────────────────────────────
DEBUG_PORT=9222

# ── Headless (visible by default so you can log in / see what happens) ──
HEADLESS=false
